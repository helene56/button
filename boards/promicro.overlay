	kbd0: kbd_matrix {
		compatible = "gpio-kbd-matrix";
		row-gpios = <&gpio0 20 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>,
					<&gpio0 24 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>,
					<&gpio1 6 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
		col-gpios = <&gpio0 22 GPIO_ACTIVE_LOW>,
					<&gpio0 11 GPIO_ACTIVE_LOW>,
					<&gpio1 4 GPIO_ACTIVE_LOW>;
		no-ghostkey-check;
	};

};
